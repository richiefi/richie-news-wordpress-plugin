{
	"name": "@richie/richie-plugins",
	"version": "1.0.0",
	"description": "Richie Platform WordPress Plugins",
	"private": true,
	"workspaces": [
		"richie",
		"richie/admin/feed-editor"
	],
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"release": "release-it",
		"release:minor": "release-it minor",
		"release:major": "release-it major",
		"plugin-zip": "zip -r richie.zip richie -x 'richie/.*' -x 'richie/tests/*' -x 'richie/bin/*' -x 'richie/.circleci/*' -x 'richie/phpunit.xml.dist*' -x 'richie/runtests.sh' -x '*.po~' -x '*.zip'",
		"build:feed-editor": "npm run build --workspace=richie/admin/feed-editor",
		"start:feed-editor": "npm run start --workspace=richie/admin/feed-editor"
	},
	"author": "Richie Oy",
	"license": "GPL-2.0-or-later",
	"devDependencies": {
		"@release-it/bumper": "7.0.5",
		"@release-it/conventional-changelog": "10.0.4",
		"@wordpress/scripts": "31.4.0",
		"release-it": "19.2.4"
	},
	"browserslist": [
		"defaults"
	]
}
